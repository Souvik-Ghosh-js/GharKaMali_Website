# ─── GharKaMali Website — Environment Variables ──────────────────────────────
# Copy this file to `.env.local` and fill in real values.
# All browser-exposed vars MUST be prefixed with NEXT_PUBLIC_.

# Backend API base URL (include the /api path).
# Local backend example: http://localhost:3000/api
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Google Maps key — enable "Maps JavaScript API" + "Places API" in Google Cloud.
# Used by the address picker and geocoding.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Public site URL — used for SEO metadata, sitemap, and canonical links.
# For local dev you can use http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://gharkamali.com
